{
  "name": "slack-connector",
  "version": "0.1.0",
  "displayName": "Slack Connector",
  "description": "Provides credential-scoped local MCP commands for preparing, inspecting, and posting Slack cowork messages.",
  "author": {
    "name": "Pith"
  },
  "capabilities": [
    "command:slack.prepare-message-draft",
    "command:slack.inspect-message-send",
    "command:slack.post-message-draft",
    "connector:slack",
    "connector_workflow:slack.post-message",
    "mcp_server:slack",
    "prompt_pack:slack.workspace"
  ],
  "permissions": [
    "network.outbound",
    "mcp.connect"
  ],
  "skills": [
    {
      "id": "slack.workspace",
      "description": "Guidance for turning local workspace context into safe Slack cowork updates.",
      "path": "skills/slack-workspace.md"
    }
  ],
  "mcpServers": [
    {
      "id": "slack",
      "transport": "stdio",
      "command": "bin/slack-mcp-local-message.sh"
    }
  ],
  "appConnectors": [
    {
      "id": "slack",
      "displayName": "Slack",
      "service": "slack",
      "homepage": "https://slack.com"
    }
  ],
  "connectorWorkflows": [
    {
      "id": "slack.post-message",
      "displayName": "Slack Post Message",
      "connectorId": "slack",
      "action": "postMessage",
      "maxAgentSteps": 5,
      "stages": [
        "draftPrepared",
        "inspectBeforeWrite",
        "blockedBeforeWrite",
        "completed",
        "failedBeforeProof"
      ],
      "statuses": [
        "prepared",
        "inspected",
        "completed",
        "retryNeeded"
      ]
    }
  ],
  "authPolicy": {
    "type": "api_key",
    "required": true,
    "scopes": [
      "chat:write"
    ],
    "credentialStore": "local"
  },
  "defaultEnabled": false
}
