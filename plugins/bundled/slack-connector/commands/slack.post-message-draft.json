{
  "title": "Post Slack Message Draft",
  "description": "Post an approved message to Slack using the authorized Slack bot token.",
  "prompt": "Post the approved local draft to Slack. Accept a valid channelId plus message text in the command input. Do not post unless the user has approved this connector action.",
  "execution": {
    "kind": "mcp.slack.postMessageDraft",
    "driver": "mcp",
    "entrypoint": "slack.postMessageDraft",
    "connectors": ["slack"],
    "workflowId": "slack.post-message",
    "input": {
      "envelope": "slack.postMessageDraft.input",
      "fields": [
        {
          "name": "input",
          "kind": "text",
          "required": true,
          "description": "Plain text or JSON containing a valid channelId and Slack message text. Pith requests approval before any remote Slack write."
        },
        {
          "name": "connectors",
          "kind": "connectorRefs",
          "required": true,
          "description": "Authorized Slack connector reference."
        }
      ]
    },
    "output": {
      "envelope": "slack.postMessageDraft.output",
      "fields": [
        {
          "name": "items",
          "kind": "timelineItems",
          "required": true,
          "description": "Remote write proof timeline item."
        },
        {
          "name": "memoryNotes",
          "kind": "memoryNotes",
          "required": false,
          "description": "Optional connector memory notes."
        }
      ]
    }
  },
  "memory": {
    "noteTitle": "Slack Message Posted",
    "noteSource": "plugin.slack-connector",
    "noteTags": ["connector", "slack", "posted"]
  }
}
