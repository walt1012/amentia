{
  "name": "notion-connector",
  "version": "0.1.0",
  "displayName": "Notion Connector",
  "description": "Provides a credential-scoped local MCP command for preparing Notion-ready workspace drafts before any remote write.",
  "author": {
    "name": "Pith"
  },
  "capabilities": [
    "command:notion.prepare-page-draft",
    "connector:notion",
    "mcp_server:notion",
    "prompt_pack:notion.workspace"
  ],
  "permissions": [
    "network.outbound",
    "mcp.connect"
  ],
  "skills": [
    {
      "id": "notion.workspace",
      "description": "Guidance for turning local workspace context into Notion-ready pages and notes.",
      "path": "skills/notion-workspace.md"
    }
  ],
  "mcpServers": [
    {
      "id": "notion",
      "transport": "stdio",
      "command": "bin/notion-mcp-local-draft.sh"
    }
  ],
  "appConnectors": [
    {
      "id": "notion",
      "displayName": "Notion",
      "service": "notion",
      "homepage": "https://www.notion.so"
    }
  ],
  "authPolicy": {
    "type": "oauth2",
    "required": true,
    "scopes": [
      "read_content",
      "insert_content"
    ],
    "credentialStore": "local"
  },
  "defaultEnabled": false
}
